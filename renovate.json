{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableDependencyDashboard",
    ":renovatePrefix",
    ":configMigration"
  ],
  "ignoreDeps": [
    "io.github.lemkinator:common-utils"
  ],
  "platformAutomerge": true,
  "packageRules": [
    {
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "groupName": "kotlin",
      "matchPackageNames": [
        "org.jetbrains.kotlin:**",
        "org.jetbrains.kotlin.*:**",
        "com.google.devtools.ksp**"
      ]
    },
    {
      "groupName": "hilt",
      "matchPackageNames": [
        "com.google.dagger**"
      ]
    },
    {
      "groupName": "github-actions",
      "matchManagers": [
        "github-actions"
      ]
    }
  ]
}
